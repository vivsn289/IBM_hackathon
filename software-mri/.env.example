# Copy this file to .env and fill in your values.

# --- IBM Bob ---
# The endpoint where your local Bob instance is reachable.
# If your Bob install exposes a REST API, set its base URL here.
# If Bob is invoked via CLI, leave BOB_ENDPOINT empty and set BOB_CLI_PATH.
BOB_ENDPOINT=http://localhost:7070
BOB_API_KEY=

# Optional: path to the bob CLI binary if you prefer CLI mode
BOB_CLI_PATH=

# Bob model identifier (if your install supports multiple)
BOB_MODEL=bob-default

# --- Analyzer ---
# Default repo path to analyze on startup. Relative to project root.
DEFAULT_REPO_PATH=./sample-repo

# Max files to analyze (safety limit for huge repos during demo)
MAX_FILES=2000

# --- Server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
